{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Asphalt",
  "version": "0.1.0",
  "identifier": "org.runwayproject.asphalt",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Asphalt",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 720,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ],
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}